
estado = noone


// guarda o estado original
estado_padrao = noone

estado_visivel =function()
{
    
    visible = true;
    mask_index = sprite_index
    colidivel = true
}

estado_invisivel=function()
{
    visible = false;
    mask_index = Spr_vazio
    colidivel = false
}


estado = estado_visivel
estado_padrao = estado_visivel
